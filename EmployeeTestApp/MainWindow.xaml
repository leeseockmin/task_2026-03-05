<Window x:Class="EmployeeTestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="직원 API 테스트 (POST /api/employee)"
        Width="860" Height="720"
        MinWidth="700" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <!-- API URL 설정 -->
        <GroupBox Grid.Row="0" Header="API 서버 설정" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="4">
                <Label Content="Base URL:"/>
                <TextBox x:Name="TxtBaseUrl" Width="380" Text="https://localhost:7000"/>
                <Button Content="연결 확인" Click="BtnPing_Click"/>
                <TextBlock x:Name="TxtPingResult" VerticalAlignment="Center" Margin="8,0" FontSize="12"/>
            </StackPanel>
        </GroupBox>

        <!-- POST 탭 (직접입력 / CSV / JSON) -->
        <GroupBox Grid.Row="1" Header="직원 등록 — POST /api/employee" Margin="0,0,0,8">
            <TabControl x:Name="TabInput" Margin="4">

                <!-- 탭 1: 직접 입력 -->
                <TabItem Header="직접 입력">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="이름 *"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtName"/>

                        <Label Grid.Row="0" Grid.Column="2" Content="이메일 *"/>
                        <TextBox Grid.Row="0" Grid.Column="3" x:Name="TxtEmail"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="전화번호 *"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtTel"/>

                        <Label Grid.Row="1" Grid.Column="2" Content="입사일 *"/>
                        <DatePicker Grid.Row="1" Grid.Column="3" x:Name="DpJoined" Margin="4,2"/>

                        <Button Grid.Row="2" Grid.Column="3" Content="등록" HorizontalAlignment="Right"
                                Click="BtnDirectCreate_Click"/>
                    </Grid>
                </TabItem>

                <!-- 탭 2: CSV 파일 -->
                <TabItem Header="CSV 파일 업로드">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="120"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Margin="0,0,0,4" FontSize="11" Foreground="Gray"
                                   Text="CSV 형식: name,email,tel,joined (첫 행은 헤더, joined는 yyyy-MM-dd)"/>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="파일 선택" Click="BtnSelectCsv_Click"/>
                            <TextBlock x:Name="TxtCsvPath" VerticalAlignment="Center" Margin="8,0"
                                       FontSize="12" Foreground="#555"/>
                        </StackPanel>

                        <DataGrid Grid.Row="2" x:Name="GridCsvPreview"
                                  AutoGenerateColumns="True" IsReadOnly="True"
                                  CanUserAddRows="False" FontSize="12"/>

                        <Button Grid.Row="3" Content="전체 전송" HorizontalAlignment="Right"
                                Margin="0,6,0,0" Click="BtnSendCsv_Click"/>
                    </Grid>
                </TabItem>

                <!-- 탭 3: JSON 파일 -->
                <TabItem Header="JSON 파일 업로드">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="120"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Margin="0,0,0,4" FontSize="11" Foreground="Gray"
                                   Text='JSON 형식: [{"name":"홍길동","email":"...","tel":"...","joined":"yyyy-MM-dd"}]'/>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="파일 선택" Click="BtnSelectJson_Click"/>
                            <TextBlock x:Name="TxtJsonPath" VerticalAlignment="Center" Margin="8,0"
                                       FontSize="12" Foreground="#555"/>
                        </StackPanel>

                        <DataGrid Grid.Row="2" x:Name="GridJsonPreview"
                                  AutoGenerateColumns="True" IsReadOnly="True"
                                  CanUserAddRows="False" FontSize="12"/>

                        <Button Grid.Row="3" Content="전체 전송" HorizontalAlignment="Right"
                                Margin="0,6,0,0" Click="BtnSendJson_Click"/>
                    </Grid>
                </TabItem>

            </TabControl>
        </GroupBox>

        <!-- 결과 로그 -->
        <GroupBox Grid.Row="2" Header="처리 결과 로그" Margin="0,0,0,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="TxtLog" IsReadOnly="True" TextWrapping="Wrap"
                         FontSize="12" FontFamily="Consolas"
                         Background="#F8F8F8" BorderThickness="0"
                         VerticalAlignment="Stretch"/>
            </ScrollViewer>
        </GroupBox>

        <!-- GET 조회 영역 -->
        <GroupBox Grid.Row="3" Header="직원 조회" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="4">
                <Button Content="전체 목록 조회 (GET /api/employee)" Click="BtnGetList_Click"/>
                <Label Content="이름으로 조회:"/>
                <TextBox x:Name="TxtSearchName" Width="160"/>
                <Button Content="검색 (GET /api/employee/{name})" Click="BtnGetByName_Click"/>
            </StackPanel>
        </GroupBox>

        <!-- 조회 결과 DataGrid -->
        <GroupBox Grid.Row="4" Header="조회 결과">
            <DataGrid x:Name="GridResult"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding EmployeeId}" Width="60"/>
                    <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="120"/>
                    <DataGridTextColumn Header="이메일" Binding="{Binding Email}" Width="220"/>
                    <DataGridTextColumn Header="전화번호" Binding="{Binding Tel}" Width="140"/>
                    <DataGridTextColumn Header="입사일" Binding="{Binding Joined, StringFormat=yyyy-MM-dd}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>
