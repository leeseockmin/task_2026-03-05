<Window x:Class="EmployeeTestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee API 테스트 도구" Height="750" Width="950"
        MinHeight="650" MinWidth="800"
        Background="#F0F2F5">

    <Window.Resources>

        <!-- 기본 버튼 스타일 -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="14,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 보조 버튼 스타일 -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#EEEEEE"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="10,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 전송 버튼 스타일 -->
        <Style x:Key="SendBtn" TargetType="Button">
            <Setter Property="Background" Value="#388E3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="16,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E7D32"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 공통 TextBox 스타일 -->
        <Style x:Key="CodeBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>

        <!-- 힌트 박스 스타일 -->
        <Style x:Key="HintBox" TargetType="Border">
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="BorderBrush" Value="#90CAF9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 상단 서버 설정 -->
            <RowDefinition Height="*"/>
            <!-- 탭 컨트롤 -->
            <RowDefinition Height="220"/>
            <!-- 로그 영역 -->
        </Grid.RowDefinitions>

        <!-- ===== 상단: 서버 URL 설정 ===== -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="서버 URL"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#424242"
                           Margin="0,0,10,0"/>

                <TextBox Grid.Column="1"
                         x:Name="TxtBaseUrl"
                         Height="32"
                         Padding="8,4"
                         FontSize="13"
                         Text="http://localhost:5136"
                         VerticalContentAlignment="Center"
                         BorderBrush="#BDBDBD"
                         BorderThickness="1"/>

                <TextBlock Grid.Column="2"
                           x:Name="TxtStatus"
                           Text=""
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           FontSize="12"
                           Foreground="#757575"/>

                <Button Grid.Column="3"
                        Style="{StaticResource SecondaryBtn}"
                        Content="로그 지우기"
                        Click="BtnClearLog_Click"/>
            </Grid>
        </Border>

        <!-- ===== 중앙: 탭 컨트롤 ===== -->
        <TabControl Grid.Row="1"
                    Margin="16,16,16,8"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    FontSize="13">

            <!-- ─────────────────────────── Tab 1: CSV 파일 업로드 ─────────────────────────── -->
            <TabItem Header="  CSV 파일 업로드  ">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 힌트 -->
                    <Border Grid.Row="0" Style="{StaticResource HintBox}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="CSV 형식 안내" FontWeight="Bold" FontSize="12" Foreground="#1565C0" Margin="0,0,0,4"/>
                            <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#424242"
                                       Text="이름,이메일,전화번호,입사일&#x0a;예) 홍길동,hong@example.com,01025862222,2018.03.07&#x0a;    김철수,kim@example.com,01012345678,2020.01.15"/>
                        </StackPanel>
                    </Border>

                    <!-- 파일 선택 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Style="{StaticResource PrimaryBtn}"
                                Content="파일 선택 (.csv)"
                                Click="BtnSelectCsvFile_Click"
                                Width="140"/>
                        <TextBlock x:Name="TxtCsvFilePath"
                                   Text="선택된 파일 없음"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   Foreground="#757575"
                                   FontSize="12"/>
                    </StackPanel>

                    <!-- 파일 내용 미리보기 -->
                    <TextBox Grid.Row="2"
                             x:Name="TxtCsvFileContent"
                             Style="{StaticResource CodeBox}"
                             IsReadOnly="True"
                             Background="#F5F5F5"
                             Text="파일을 선택하면 내용이 표시됩니다."/>

                    <!-- 전송 -->
                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtCsvFileParseInfo"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#757575"/>
                        <Button Grid.Column="1"
                                Style="{StaticResource SendBtn}"
                                Content="POST /api/Employee"
                                Click="BtnSendCsvFile_Click"
                                Width="180"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─────────────────────────── Tab 2: JSON 파일 업로드 ─────────────────────────── -->
            <TabItem Header="  JSON 파일 업로드  ">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 힌트 -->
                    <Border Grid.Row="0" Style="{StaticResource HintBox}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="JSON 형식 안내" FontWeight="Bold" FontSize="12" Foreground="#1565C0" Margin="0,0,0,4"/>
                            <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#424242"
                                       Text='[&#x0a;  { "name": "홍길동", "email": "hong@example.com", "tel": "010-1111-2424", "joined": "2012-01-05" },&#x0a;  { "name": "김철수", "email": "kim@example.com",  "tel": "010-2222-3333", "joined": "2020-03-15" }&#x0a;]'/>
                        </StackPanel>
                    </Border>

                    <!-- 파일 선택 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Style="{StaticResource PrimaryBtn}"
                                Content="파일 선택 (.json)"
                                Click="BtnSelectJsonFile_Click"
                                Width="140"/>
                        <TextBlock x:Name="TxtJsonFilePath"
                                   Text="선택된 파일 없음"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   Foreground="#757575"
                                   FontSize="12"/>
                    </StackPanel>

                    <!-- 파일 내용 미리보기 -->
                    <TextBox Grid.Row="2"
                             x:Name="TxtJsonFileContent"
                             Style="{StaticResource CodeBox}"
                             IsReadOnly="True"
                             Background="#F5F5F5"
                             Text="파일을 선택하면 내용이 표시됩니다."/>

                    <!-- 전송 -->
                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtJsonFileParseInfo"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#757575"/>
                        <Button Grid.Column="1"
                                Style="{StaticResource SendBtn}"
                                Content="POST /api/Employee"
                                Click="BtnSendJsonFile_Click"
                                Width="180"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─────────────────────────── Tab 3: CSV 직접 입력 ─────────────────────────── -->
            <TabItem Header="  CSV 직접 입력  ">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 힌트 -->
                    <Border Grid.Row="0" Style="{StaticResource HintBox}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="CSV 형식: 이름,이메일,전화번호,입사일(yyyy.MM.dd) — 한 줄에 한 명, 헤더 없이 입력"
                                       FontSize="12" Foreground="#1565C0"/>
                        </StackPanel>
                    </Border>

                    <!-- 입력 -->
                    <TextBox Grid.Row="1"
                             x:Name="TxtCsvBody"
                             Style="{StaticResource CodeBox}"
                             Text="홍길동,hong@example.com,01025862222,2018.03.07&#x0a;김철수,kim@example.com,01012345678,2020.01.15"
                             TextChanged="TxtCsvBody_TextChanged"/>

                    <!-- 전송 -->
                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtCsvBodyParseInfo"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#757575"/>
                        <Button Grid.Column="1"
                                Style="{StaticResource SecondaryBtn}"
                                Content="초기화"
                                Click="BtnResetCsvBody_Click"/>
                        <Button Grid.Column="3"
                                Style="{StaticResource SendBtn}"
                                Content="POST /api/Employee"
                                Click="BtnSendCsvBody_Click"
                                Width="180"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─────────────────────────── Tab 4: JSON 직접 입력 ─────────────────────────── -->
            <TabItem Header="  JSON 직접 입력  ">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 힌트 -->
                    <Border Grid.Row="0" Style="{StaticResource HintBox}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="JSON 형식: name, email, tel, joined(yyyy-MM-dd) — 배열 형태로 입력"
                                       FontSize="12" Foreground="#1565C0"/>
                        </StackPanel>
                    </Border>

                    <!-- 입력 -->
                    <TextBox Grid.Row="1"
                             x:Name="TxtJsonBody"
                             Style="{StaticResource CodeBox}"
                             TextChanged="TxtJsonBody_TextChanged">
                        <TextBox.Text><![CDATA[[
  { "name": "홍길동", "email": "hong@example.com", "tel": "010-1111-2424", "joined": "2012-01-05" },
  { "name": "김철수", "email": "kim@example.com",  "tel": "010-2222-3333", "joined": "2020-03-15" }
]]]></TextBox.Text>
                    </TextBox>

                    <!-- 전송 -->
                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtJsonBodyParseInfo"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#757575"/>
                        <Button Grid.Column="1"
                                Style="{StaticResource SecondaryBtn}"
                                Content="초기화"
                                Click="BtnResetJsonBody_Click"/>
                        <Button Grid.Column="3"
                                Style="{StaticResource SendBtn}"
                                Content="POST /api/Employee"
                                Click="BtnSendJsonBody_Click"
                                Width="180"/>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ===== 하단: 응답 로그 ===== -->
        <Border Grid.Row="2"
                Margin="16,0,16,16"
                Background="#1E1E1E"
                CornerRadius="6"
                BorderBrush="#333333"
                BorderThickness="1">
            <Grid Margin="12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="응답 로그"
                           Foreground="#9E9E9E"
                           FontSize="11"
                           FontFamily="Consolas"
                           Margin="0,0,0,6"/>

                <TextBox Grid.Row="1"
                         x:Name="TxtLog"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="Transparent"
                         Foreground="#D4D4D4"
                         BorderThickness="0"
                         Padding="0"
                         CaretBrush="#D4D4D4"/>
            </Grid>
        </Border>

    </Grid>
</Window>
