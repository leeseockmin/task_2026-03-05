# =============================================================
# C# / ASP.NET Core .gitignore
# 작성자: Senior Developer
# =============================================================

# ---------------------------------------------------------------
# Root hidden files / directories
# Keep repository metadata that is intentionally versioned.
# ---------------------------------------------------------------
/.*
!/.github/
!/.github/**
!/.gitattributes
!/.gitignore
!/.gitmodules

# ---------------------------------------------------------------
# 빌드 결과물
# ---------------------------------------------------------------
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/


# ---------------------------------------------------------------
# Visual Studio 관련
# ---------------------------------------------------------------
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs

# Visual Studio 코드 분석
*.aps
*.ncb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# Visual Studio 프로파일러
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Trace
*.e2e

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JetBrains Rider
.idea/
*.sln.iml

# DotCover
*.dotCover

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*


# ---------------------------------------------------------------
# .NET / NuGet
# ---------------------------------------------------------------
*.nupkg
*.snupkg
**/[Pp]ackages/
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json
artifacts/

# NuGet 심볼 패키지
*.symbols.nupkg


# ---------------------------------------------------------------
# ASP.NET Core
# ---------------------------------------------------------------
# 게시(Publish) 결과물
**/publish/
**/PublishProfiles/

# 정적 파일 번들
bundleconfig.json.bak

# ASP.NET Core 개발 인증서
*.pfx

# Entity Framework Core 마이그레이션 스냅샷 백업
*.bak


# ---------------------------------------------------------------
# 환경 설정 / 시크릿 (절대 커밋 금지)
# ---------------------------------------------------------------
appsettings.Development.json
appsettings.Local.json
appsettings.Production.json
appsettings.Staging.json
secrets.json
**/secrets.json
*.env
.env
.env.*
!.env.example

# ASP.NET Core User Secrets
# %APPDATA%\Microsoft\UserSecrets 는 프로젝트 외부이므로 자동 제외되지만
# 혹시 프로젝트 안에 포함될 경우 대비
**/UserSecrets/


# ---------------------------------------------------------------
# 로그 파일 (Serilog 포함)
# ---------------------------------------------------------------
*.log
*.log.*
[Ll]ogs/
log/


# ---------------------------------------------------------------
# 테스트 결과
# ---------------------------------------------------------------
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResult.xml
coverage*.xml
coverage*.json
coverage*.info
*.trx
*.coverage
*.coveragexml


# ---------------------------------------------------------------
# Windows OS 파일
# ---------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk


# ---------------------------------------------------------------
# macOS (팀원 환경 대비)
# ---------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent


# ---------------------------------------------------------------
# Linux (팀원 환경 대비)
# ---------------------------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# ---------------------------------------------------------------
# Docker
# ---------------------------------------------------------------
.dockerignore
docker-compose.override.yml
docker-compose.*.local.yml


# ---------------------------------------------------------------
# 기타 에디터 / 도구
# ---------------------------------------------------------------
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# Terraform (인프라 코드 포함 시)
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example


# ---------------------------------------------------------------
# 임시 파일
# ---------------------------------------------------------------
*.tmp
*.temp
*.swp
*.orig
*.pid
